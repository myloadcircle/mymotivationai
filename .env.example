# ============================================
# MotivationAI - Environment Configuration
# ============================================

# Supabase (required for hybrid app and offline-first)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Application URLs (Update for production)
NEXT_PUBLIC_APP_URL=https://mymotivationai.com
NEXT_PUBLIC_API_URL=https://api.mymotivationai.com
NEXTAUTH_URL=https://mymotivationai.com
NEXTAUTH_SECRET=your-nextauth-secret-key-here-minimum-32-characters

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/mymotivationai
# Production: postgresql://username:password@host:port/database

# Authentication Providers
# GitHub OAuth
GITHUB_ID=your-github-oauth-client-id
GITHUB_SECRET=your-github-oauth-client-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Email Configuration (for passwordless/auth emails)
EMAIL_SERVER=smtp://username:password@smtp.example.com:587
EMAIL_FROM=noreply@mymotivationai.com

# AI Service Configuration (Optional)
OPENAI_API_KEY=your-openai-api-key-optional
GOOGLE_AI_KEY=your-google-ai-api-key-optional
AI_SERVICE_ENABLED=true

# Stripe Configuration (Production - get from Stripe Dashboard)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Stripe Price IDs (Production - create in Stripe Dashboard)
STRIPE_BASIC_PRICE_ID=your-basic-price-id
STRIPE_PRO_PRICE_ID=your-pro-price-id
STRIPE_ENTERPRISE_PRICE_ID=your-enterprise-price-id

# Community & Gamification Configuration
COMMUNITY_FEATURES_ENABLED=true
GAMIFICATION_ENABLED=true
MAX_GROUP_SIZE=1000
REAL_TIME_UPDATES_ENABLED=true

# Analytics & Monitoring
ANALYTICS_ENABLED=true
SENTRY_DSN=your-sentry-dsn-optional
LOG_LEVEL=info

# Security Configuration
SESSION_MAX_AGE=30 # days
RATE_LIMIT_ENABLED=true
CORS_ORIGINS=https://mymotivationai.com,https://www.mymotivationai.com

# Deployment Configuration
NODE_ENV=production
PORT=3000