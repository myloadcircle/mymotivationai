  "shortcuts": [
    {
      "name": "Daily Motivation",
      "short_name": "Daily",
      "description": "Get today's personalized motivation exercise",
      "url": "/app/daily?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-daily.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Progress Dashboard",
      "short_name": "Progress",
      "description": "View your motivation progress and streaks",
      "url": "/app/dashboard?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-progress.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "New Exercise",
      "short_name": "New",
      "description": "Start a new motivation exercise",
      "url": "/app/exercises/new?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-new.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+mymotivationai",
      "url": "/app?protocol=%s"
    }
  ],
  "share_target": {
    "action": "/app/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.mymotivationai.app",
      "id": "com.mymotivationai.app"
    },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/mymotivationai/id1234567890"
    }
  ],
  "prefer_related_applications": false
}